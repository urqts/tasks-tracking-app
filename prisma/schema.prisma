// TaskFlow Prisma schema
// PostgreSQL (Supabase). UUID primary keys, createdAt/updatedAt on every model,
// and soft-delete support via a nullable `deletedAt` column.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  ARCHIVED
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum ReminderChannel {
  BROWSER
  EMAIL
}

enum NotificationType {
  DUE_TODAY
  DUE_TOMORROW
  OVERDUE
  TASK_ASSIGNED
  TASK_COMPLETED
  PROJECT_DEADLINE
  SYSTEM
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  COMPLETED
  STATUS_CHANGED
  COMMENTED
  ATTACHED
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum DefaultView {
  LIST
  BOARD
  CALENDAR
  DASHBOARD
}

// ---------------------------------------------------------------------------
// Core models
// ---------------------------------------------------------------------------

/// Mirrors the Supabase auth user. `id` equals the Supabase auth.users id so
/// we can join app data to the authenticated user without a second lookup.
model User {
  id            String    @id @db.Uuid
  email         String    @unique
  name          String?
  avatarUrl     String?
  emailVerified DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tasks         Task[]
  subtasks      Subtask[]
  projects      Project[]
  categories    Category[]
  tags          Tag[]
  attachments   Attachment[]
  reminders     Reminder[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  recurringTasks RecurringTask[]
  settings      Settings?

  @@index([email])
  @@map("users")
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  color       String    @default("#6366f1")
  deadline    DateTime?
  archived    Boolean   @default(false)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("projects")
}

model Category {
  id    String @id @default(uuid()) @db.Uuid
  name  String
  color String @default("#64748b")
  icon  String?

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Tag {
  id    String @id @default(uuid()) @db.Uuid
  name  String
  color String @default("#0ea5e9")

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskTags TaskTag[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)

  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?

  // Estimated / actual time in minutes
  estimatedMinutes Int?
  actualMinutes    Int?

  // Manual ordering within a status column (kanban) and within lists
  position Int @default(0)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  categoryId String?   @db.Uuid
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  recurringTaskId String?        @db.Uuid
  recurringTask   RecurringTask? @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)

  subtasks    Subtask[]
  taskTags    TaskTag[]
  attachments Attachment[]
  reminders   Reminder[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([projectId])
  @@index([categoryId])
  @@index([userId, deletedAt])
  @@map("tasks")
}

model Subtask {
  id        String  @id @default(uuid()) @db.Uuid
  title     String
  completed Boolean @default(false)
  position  Int     @default(0)

  // Nested subtasks: a subtask may have a parent subtask.
  parentId String?   @db.Uuid
  parent   Subtask?  @relation("SubtaskChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children Subtask[] @relation("SubtaskChildren")

  taskId String @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([taskId])
  @@index([parentId])
  @@map("subtasks")
}

/// Explicit many-to-many join between Task and Tag.
model TaskTag {
  taskId String @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  tagId String @db.Uuid
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([taskId, tagId])
  @@index([tagId])
  @@map("task_tags")
}

model Attachment {
  id        String @id @default(uuid()) @db.Uuid
  fileName  String
  fileType  String
  fileSize  Int
  // Path within the Supabase Storage bucket
  storagePath String

  taskId String @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([taskId])
  @@map("attachments")
}

model Reminder {
  id        String          @id @default(uuid()) @db.Uuid
  remindAt  DateTime
  channel   ReminderChannel @default(BROWSER)
  sent      Boolean         @default(false)
  sentAt    DateTime?

  taskId String @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, sent, remindAt])
  @@index([taskId])
  @@map("reminders")
}

model Notification {
  id      String           @id @default(uuid()) @db.Uuid
  type    NotificationType
  title   String
  body    String?
  read    Boolean          @default(false)
  // Optional deep link, e.g. /tasks/<id>
  link    String?

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id         String         @id @default(uuid()) @db.Uuid
  action     ActivityAction
  entityType String // "task" | "project" | "subtask" ...
  entityId   String @db.Uuid
  // Free-form JSON describing the change (before/after, etc.)
  metadata   Json?

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model RecurringTask {
  id        String              @id @default(uuid()) @db.Uuid
  title     String
  frequency RecurrenceFrequency
  // Every N units of `frequency` (e.g. every 2 weeks)
  interval  Int                 @default(1)
  // For WEEKLY: comma-separated weekday numbers 0-6 (e.g. "1,3,5")
  byWeekday String?
  // For MONTHLY: day of month 1-31
  byMonthDay Int?

  startDate DateTime
  endDate   DateTime?
  // The last date for which a concrete Task was generated
  lastRunAt DateTime?
  nextRunAt DateTime?
  active    Boolean   @default(true)

  // Template fields copied onto each generated task
  priority         Priority   @default(MEDIUM)
  defaultStatus    TaskStatus @default(TODO)
  estimatedMinutes Int?
  categoryId       String?    @db.Uuid
  projectId        String?    @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, active, nextRunAt])
  @@map("recurring_tasks")
}

model Settings {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme       ThemePreference @default(SYSTEM)
  defaultView DefaultView     @default(DASHBOARD)
  timezone    String          @default("UTC")
  language    String          @default("en")
  weekStartsOn Int            @default(1) // 0 = Sunday, 1 = Monday

  // Notification preferences
  browserNotifications Boolean @default(true)
  emailNotifications   Boolean @default(true)
  notifyDueToday       Boolean @default(true)
  notifyDueTomorrow    Boolean @default(true)
  notifyOverdue        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
